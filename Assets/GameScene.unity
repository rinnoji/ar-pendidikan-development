  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DecisionManager
  questionTextMesh: {fileID: 1006080912}
  answerButtons:
  - {fileID: 1277270659}
  - {fileID: 777755416}
  - {fileID: 794493733}
  - {fileID: 256028017}
  timerTextMesh: {fileID: 1688740360}
  resultPanel: {fileID: 453143705}
  resultTextMesh: {fileID: 805724862}
  backToMenuButton: {fileID: 369532322}
  feedbackPanel: {fileID: 1237738648}
  feedbackTextMesh: {fileID: 555307646}
  nextButton: {fileID: 1640900503}
  stages:
  - stageName: Gempa
    questionText: '"Apa yang harus dilakukan saat terjadi gempa di dalam kelas?"'
    answers:
    - Berlindung di Bawah Meja
    - Keluar Pintu
    - Naik Tangga ke atas
    - Naik ke atas Lemari
    correctAnswerIndex: 0
    educationFeedback: Sembunyi di bawah meja yang kuat untuk melindungi kepala dan
      leher dari reruntuhan benda dari atas.
    stageVisualContainer: {fileID: 718786322}
  - stageName: Kebakaran
    questionText: Kamu melihat asap tebal dan api mulai membesar di dalam ruangan.
      Apa tindakan pertama yang paling tepat untuk menyelamatkan diri?
    answers:
    - Sembunyi di dalam lemari atau kamar mandi
    - Merayap di bawah asap menuju jalur evakuasi
    - Membuka semua jendela lebar-lebar
    - Tetap berdiri tegak dan berlari kencang
    correctAnswerIndex: 1
    educationFeedback: Asap beracun berkumpul di atas. Merayaplah di lantai untuk
      mencari udara bersih saat evakuasi.
    stageVisualContainer: {fileID: 546160401}
  - stageName: Banjir
    questionText: Hujan deras turun berhari-hari dan air mulai masuk merendam rumah.
      Apa langkah evakuasi yang harus segera dilakukan?
    answers:
    - Bermain air banjir di halaman rumah
    - Mengunci rumah dari dalam dan bertahan di kamar
    - Menyentuh kabel listrik agar tidak basah
    - Matikan listrik, bawa dokumen penting, lalu pergi ke tempat tinggi
    correctAnswerIndex: 3
    educationFeedback: Listrik dan air sangat berbahaya. Segera matikan arus listrik
      dan evakuasi ke dataran tinggi.
    stageVisualContainer: {fileID: 546160401}
  timePerStage: 15
